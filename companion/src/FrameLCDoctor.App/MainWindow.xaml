<Window x:Class="FrameLCDoctor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FrameLCDoctor" Height="660" Width="560"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Text}"/></Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="H" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#15151A"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="FrameLCDoctor" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="TxtStatus" Text="buscando juego..." Foreground="{StaticResource Muted}"
                       VerticalAlignment="Bottom" Margin="12,0,0,3" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- live performance -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource H}" Text="RENDIMIENTO EN VIVO"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock x:Name="TxtFps" Text="--" FontSize="40" FontWeight="Bold"/>
                    <TextBlock Text="fps" FontSize="16" Foreground="{StaticResource Muted}" VerticalAlignment="Bottom" Margin="6,0,18,8"/>
                    <TextBlock x:Name="TxtFrametime" Text="" FontSize="14" Foreground="{StaticResource Muted}" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="GPU" VerticalAlignment="Center"/>
                    <ProgressBar x:Name="BarGpu" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtGpu" Grid.Row="0" Grid.Column="2" Text="n/a" TextAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU pico" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <ProgressBar x:Name="BarCpuPeak" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="TxtCpuPeak" Grid.Row="1" Grid.Column="2" Text="n/a" TextAlignment="Right" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU total" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <ProgressBar x:Name="BarCpuTotal" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock x:Name="TxtCpuTotal" Grid.Row="2" Grid.Column="2" Text="n/a" TextAlignment="Right" VerticalAlignment="Center" Margin="0,8,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- headroom index -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource H}" Text="INDICE DE APROVECHAMIENTO"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border x:Name="Badge" CornerRadius="5" Padding="8,3" Background="#555">
                        <TextBlock x:Name="TxtBottleneck" Text="--" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="margen libre:" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <TextBlock x:Name="TxtHeadroom" Text="--" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="%" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="2,2,0,0"/>
                    <TextBlock x:Name="TxtMoreFps" Text="" VerticalAlignment="Center" Margin="18,0,0,0" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock x:Name="TxtVerdict" Text="Conecta el juego para diagnosticar." TextWrapping="Wrap" Margin="0,2,0,4"/>
                <TextBlock x:Name="TxtSuggestion" Text="" TextWrapping="Wrap" Foreground="{StaticResource Muted}"/>
            </StackPanel>
        </Border>

        <!-- remedies -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource H}" Text="REMEDIOS"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Limite FPS" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="SliderFps" Grid.Column="1" Minimum="0" Maximum="240" Value="60"
                            TickFrequency="30" IsSnapToTickEnabled="False" VerticalAlignment="Center"
                            ValueChanged="SliderFps_ValueChanged"/>
                    <TextBlock x:Name="TxtFpsVal" Grid.Column="2" Text="60" Width="64" TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="presents/frame" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                    <TextBox x:Name="TxtPpf" Text="2" Width="40" Margin="8,0,0,0" Background="#15151A" Foreground="{StaticResource Text}" BorderBrush="#444"/>
                    <Button x:Name="BtnApply" Content="Aplicar" Padding="16,5" Margin="18,0,0,0" Click="BtnApply_Click"/>
                    <TextBlock Text="(0 = sin limite)" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
