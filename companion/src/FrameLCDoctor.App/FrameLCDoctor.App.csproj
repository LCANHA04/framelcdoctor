<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>FrameLCDoctor</RootNamespace>
    <AssemblyName>FrameLCDoctor</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Platforms>x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <!-- prebuilt proxies the launcher deploys into game folders -->
    <Content Include="proxies\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>proxies\%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>

</Project>
