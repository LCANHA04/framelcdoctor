<Window x:Class="FrameLCDoctor.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FrameLCDoctor - Juegos" Height="500" Width="720"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Text}"/></Style>
        <Style TargetType="Button"><Setter Property="Padding" Value="12,5"/><Setter Property="Margin" Value="0,0,8,0"/></Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- left: game list -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="JUEGOS (Steam)" Foreground="{StaticResource Muted}"
                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="BtnRefresh" Content="Refrescar" Click="BtnRefresh_Click"/>
                <Button x:Name="BtnBrowse" Content="Examinar..." Click="BtnBrowse_Click"/>
            </StackPanel>
            <ListBox x:Name="ListGames" Background="#15151A" Foreground="{StaticResource Text}"
                     BorderBrush="#333" SelectionChanged="ListGames_SelectionChanged"
                     DisplayMemberPath="Name"/>
        </DockPanel>

        <!-- right: detail + actions -->
        <Border Grid.Column="1" Background="{StaticResource Panel}" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock x:Name="TxtName" Text="Elegi un juego o usa Examinar" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtExe" Text="" Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,12"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border CornerRadius="5" Padding="8,3" Background="#3A6EC0" Margin="0,0,8,0">
                        <TextBlock x:Name="TxtApi" Text="API: --"/>
                    </Border>
                    <Border x:Name="BadgeAc" CornerRadius="5" Padding="8,3" Background="#555">
                        <TextBlock x:Name="TxtAc" Text="anti-cheat: --"/>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="TxtInstalled" Text="" Foreground="{StaticResource Muted}" Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button x:Name="BtnInstall" Content="Instalar" Click="BtnInstall_Click" IsEnabled="False"/>
                    <Button x:Name="BtnUninstall" Content="Desinstalar" Click="BtnUninstall_Click" IsEnabled="False"/>
                    <Button x:Name="BtnLaunch" Content="Lanzar juego" Click="BtnLaunch_Click" IsEnabled="False"/>
                </StackPanel>

                <Border Background="#15151A" CornerRadius="6" Padding="10" Margin="0,16,0,0">
                    <TextBlock x:Name="TxtStatus" Text="Instala el proxy, despues arranca el juego y abri el panel." TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
