<Window x:Class="FrameLCDoctor.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FrameLCDoctor - Gestor de juegos" Height="640" Width="780"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Text}"/></Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="120"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Gestor de juegos" FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Elegi un juego, instala FrameLCDoctor y abri el panel para ver y optimizar su rendimiento."
                       Foreground="{StaticResource Muted}" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- left: game list -->
            <DockPanel Grid.Column="0" Margin="0,0,14,0">
                <TextBlock DockPanel.Dock="Top" Text="TUS JUEGOS DE STEAM" Foreground="{StaticResource Muted}"
                           FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="BtnRefresh" Content="Refrescar" Click="BtnRefresh_Click"/>
                    <Button x:Name="BtnBrowse" Content="Examinar .exe..." Click="BtnBrowse_Click"
                            ToolTip="Para juegos que no son de Steam: apunta al .exe a mano."/>
                </StackPanel>
                <ListBox x:Name="ListGames" Background="#15151A" BorderBrush="#333"
                         SelectionChanged="ListGames_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#23232B" Padding="8,5" Margin="0,1" CornerRadius="3">
                                <TextBlock Text="{Binding Name}" Foreground="#F0F0F4" FontSize="13"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- right: detail -->
            <Border Grid.Column="1" Background="{StaticResource Panel}" CornerRadius="8" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="TxtName" Text="Elegi un juego de la lista (o Examinar)"
                               FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtExe" Text="" Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,16"/>

                    <!-- info rows -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Style="{StaticResource Lbl}" Text="API grafica"/>
                        <TextBlock x:Name="TxtApiVal" Text="--" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Style="{StaticResource Lbl}" Text="Anti-cheat"/>
                        <TextBlock x:Name="TxtAcVal" Text="--" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Style="{StaticResource Lbl}" Text="FrameLCDoctor"/>
                        <TextBlock x:Name="TxtInstVal" Text="--" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- actions -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnInstall" Content="Instalar" Click="BtnInstall_Click" IsEnabled="False"
                                ToolTip="Copia el proxy de FrameLCDoctor al lado del .exe del juego. No toca el juego, reversible."/>
                        <Button x:Name="BtnUninstall" Content="Desinstalar" Click="BtnUninstall_Click" IsEnabled="False"
                                ToolTip="Borra los archivos que agrego FrameLCDoctor. El juego vuelve a la normalidad."/>
                        <Button x:Name="BtnLaunch" Content="Lanzar juego" Click="BtnLaunch_Click" IsEnabled="False"
                                ToolTip="Arranca el juego (por Steam si corresponde)."/>
                    </StackPanel>

                    <!-- per-game fps preset -->
                    <StackPanel x:Name="PresetPanel" Margin="0,16,0,0" Visibility="Collapsed">
                        <TextBlock Text="PRESET FPS (gama baja)" Foreground="{StaticResource Muted}" FontWeight="SemiBold" FontSize="11"/>
                        <TextBlock x:Name="TxtPresetDesc" TextWrapping="Wrap" Foreground="{StaticResource Text}" FontSize="12" Margin="0,4,0,6"/>
                        <Border Background="#15151A" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="Cambia exactamente esto:" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtPresetChanges" TextWrapping="Wrap" Foreground="{StaticResource Text}" FontSize="12"/>
                                <TextBlock x:Name="TxtPresetFile" TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnPreset" Content="Aplicar preset FPS" Click="BtnPreset_Click"
                                    ToolTip="Baja settings pesados en el config del juego. Hace backup. Aplicar con el juego cerrado."/>
                            <Button x:Name="BtnPresetRestore" Content="Restaurar" Click="BtnPresetRestore_Click" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- help -->
                    <Border Background="#15151A" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtStatus" Text="Que hace Instalar" TextWrapping="Wrap" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtStatusDetail"
                                       Text="Deja el juego preparado para que FrameLCDoctor se enganche al abrirlo. Copia un DLL proxy + el DLL real renombrado + un ini, al lado del .exe (nunca modifica el juego). Despues arranca el juego normal y abri el panel para ver el diagnostico y aplicar remedios. Todo se deshace con Desinstalar."
                                       TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
