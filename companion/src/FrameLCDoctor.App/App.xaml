<Application x:Class="FrameLCDoctor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="LauncherWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="Bg"     Color="#1E1E24"/>
        <SolidColorBrush x:Key="Panel"  Color="#2A2A33"/>
        <SolidColorBrush x:Key="Text"   Color="#E6E6EA"/>
        <SolidColorBrush x:Key="Muted"  Color="#9A9AA6"/>
        <SolidColorBrush x:Key="Accent" Color="#4FA3FF"/>
    </Application.Resources>
</Application>
